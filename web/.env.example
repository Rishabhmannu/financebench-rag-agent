# Where the FastAPI backend lives. Only used server-side (BFF route handlers
# and proxy.ts). The browser only ever talks to Next.js.
BACKEND_URL=http://localhost:8000

# Cookie name used to store the JWT after login. Set httpOnly server-side.
SESSION_COOKIE_NAME=rag_session

# Cookie lifetime in seconds; should match (or be shorter than) backend
# JWT_EXPIRY_HOURS in src/config/settings.py.
SESSION_TTL_SECONDS=86400
